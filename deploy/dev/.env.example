# =============================================================================
# AgentsMesh Development Environment Configuration
# =============================================================================
#
# 多 Worktree 支持说明：
# 如果你使用 git worktree 管理多个分支，每个 worktree 需要独立的配置。
# 运行 ./init-worktree.sh 自动生成配置，或手动设置以下变量。
#
# =============================================================================

# -----------------------------------------------------------------------------
# 项目隔离配置 (多 Worktree 必须修改)
# -----------------------------------------------------------------------------

# Docker Compose 项目名称
# 用于隔离容器、网络和卷。每个 worktree 必须使用不同的名称。
# 示例: agentsmesh-main, agentsmesh-feature-xxx
COMPOSE_PROJECT_NAME=agentsmesh

# -----------------------------------------------------------------------------
# 端口配置 (多 Worktree 必须修改以避免冲突)
# -----------------------------------------------------------------------------

# HTTP 入口端口 (Nginx)
HTTP_PORT=80

# PostgreSQL 端口
POSTGRES_PORT=5432

# Redis 端口
REDIS_PORT=6379

# MinIO API 端口
MINIO_API_PORT=9000

# MinIO Console 端口
MINIO_CONSOLE_PORT=9001

# Adminer 端口
ADMINER_PORT=8081

# -----------------------------------------------------------------------------
# 数据库配置
# -----------------------------------------------------------------------------

POSTGRES_PASSWORD=agentsmesh_dev

# -----------------------------------------------------------------------------
# 认证配置
# -----------------------------------------------------------------------------

JWT_SECRET=dev-jwt-secret-change-in-production

# -----------------------------------------------------------------------------
# MinIO (S3 兼容存储)
# -----------------------------------------------------------------------------

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# -----------------------------------------------------------------------------
# GitHub OAuth (可选)
# -----------------------------------------------------------------------------

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Runner 配置
# -----------------------------------------------------------------------------

RUNNER_TOKEN=dev-runner-token

# -----------------------------------------------------------------------------
# 支付配置
# -----------------------------------------------------------------------------

# 部署类型: global (Stripe), cn (支付宝+微信), onpremise (授权文件)
DEPLOYMENT_TYPE=global

# Mock 支付模式 (用于测试，无需真实支付服务商)
# 设置为 true 启用 mock 支付流程
PAYMENT_MOCK=true
PAYMENT_MOCK_BASE_URL=http://localhost

# Stripe (global 部署)
# 从 https://dashboard.stripe.com/test/apikeys 获取测试密钥
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# 支付宝 (cn 部署)
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
ALIPAY_SANDBOX=true

# 微信支付 (cn 部署)
WECHAT_APP_ID=
WECHAT_MCH_ID=
WECHAT_API_KEY=
WECHAT_APIV3_KEY=
WECHAT_SANDBOX=true

# 私有部署授权
LICENSE_PUBLIC_KEY_PATH=
LICENSE_FILE_PATH=
