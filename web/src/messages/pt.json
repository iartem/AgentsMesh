      },
      "agentmesh": {
        "title": "AgentMesh",
        "subtitle": "Colaboração Multi-Agente",
        "description": "Permita que múltiplos agentes de IA trabalhem juntos através de vinculações de pods e comunicação por canais. Visualize a topologia de colaboração em tempo real.",
        "highlights": [
          "Vinculação de Pod com controle de permissões",
          "Transmissão de mensagens baseada em canais",
          "Visualização de topologia em tempo real",
          "Coordenação de tarefas entre agentes"
