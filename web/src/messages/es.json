        "highlights": {
          "0": "Visualización de tablero Kanban",
          "1": "Vinculación Ticket - Pod",
          "2": "Seguimiento de progreso",
          "3": "Integración MR/PR"
        }
      },
      "runners": {
        "title": "Runners Auto-alojados",
        "subtitle": "Tu Infraestructura, Tus Datos",
