        }
      },
      "agentsmesh": {
        "title": "AgentsMesh",
        "subtitle": "Colaboración Multi-Agente",
        "description": "Permite que múltiples agentes de IA trabajen juntos a través de enlaces de pods y comunicación por canales. Visualiza la topología de colaboración en tiempo real.",
        "highlights": {
          "0": "Enlace de Pod con control de permisos",
          "1": "Difusión de mensajes basada en canales",
          "2": "Visualización de topología en tiempo real",
          "3": "Coordinación de tareas entre agentes"
        }
      },
      "tickets": {
        "title": "Tickets",
        "subtitle": "Desarrollo Impulsado por Tareas",
