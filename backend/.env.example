# Server
SERVER_ADDRESS=:8080
DEBUG=true

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=agentsmesh
DB_PASSWORD=agentsmesh_dev
DB_NAME=agentsmesh
DB_SSLMODE=disable

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-me-in-production
JWT_EXPIRATION_HOURS=24

# OAuth - GitHub
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URL=http://localhost:3000/api/auth/callback/github

# OAuth - Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=http://localhost:3000/api/auth/callback/google

# OAuth - GitLab
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=
GITLAB_REDIRECT_URL=http://localhost:3000/api/auth/callback/gitlab

# OAuth - Gitee
GITEE_CLIENT_ID=
GITEE_CLIENT_SECRET=
GITEE_REDIRECT_URL=http://localhost:3000/api/auth/callback/gitee

# ===========================================
# Payment Configuration
# ===========================================

# Deployment Type: global | cn | onpremise
# - global: International users, use Stripe
# - cn: China users, use Alipay + WeChat Pay
# - onpremise: Self-hosted, use license file
DEPLOYMENT_TYPE=global

# Stripe (for DEPLOYMENT_TYPE=global)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Alipay (for DEPLOYMENT_TYPE=cn)
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
ALIPAY_NOTIFY_URL=
ALIPAY_RETURN_URL=
ALIPAY_SANDBOX=false

# WeChat Pay (for DEPLOYMENT_TYPE=cn)
WECHAT_APP_ID=
WECHAT_MCH_ID=
WECHAT_API_KEY=
WECHAT_APIV3_KEY=
WECHAT_CERT_PATH=
WECHAT_KEY_PATH=
WECHAT_NOTIFY_URL=
WECHAT_SANDBOX=false

# License (for DEPLOYMENT_TYPE=onpremise)
LICENSE_PUBLIC_KEY_PATH=
LICENSE_FILE_PATH=
LICENSE_SERVER_URL=

# Storage (S3-compatible: AWS S3 / MinIO / Aliyun OSS)
# For MinIO (development):
STORAGE_ENDPOINT=localhost:9000
STORAGE_REGION=us-east-1
STORAGE_BUCKET=agentsmesh
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_USE_SSL=false
STORAGE_USE_PATH_STYLE=true

# For AWS S3 (production):
# STORAGE_ENDPOINT=              # Leave empty for AWS default
# STORAGE_REGION=us-west-2
# STORAGE_BUCKET=agentsmesh-prod
# STORAGE_ACCESS_KEY=your-access-key
# STORAGE_SECRET_KEY=your-secret-key
# STORAGE_USE_SSL=true
# STORAGE_USE_PATH_STYLE=false

# For Aliyun OSS (S3-compatible mode):
# STORAGE_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
# STORAGE_REGION=oss-cn-hangzhou
# STORAGE_BUCKET=agentsmesh
# STORAGE_ACCESS_KEY=your-access-key
# STORAGE_SECRET_KEY=your-secret-key
# STORAGE_USE_SSL=true
# STORAGE_USE_PATH_STYLE=false

# Storage limits
STORAGE_MAX_FILE_SIZE=10
STORAGE_ALLOWED_TYPES=image/jpeg,image/png,image/gif,image/webp,application/pdf
